# Supabase project configuration
# Use the anon/public key only for browser-safe client access.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side Supabase access for API routes that perform CRUD and uploads.
# Never expose this value to the browser, client components, logs, or public docs.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Storage bucket for optimized WebP item photos.
# Keep this in sync with supabase/schema.sql.
SUPABASE_STORAGE_BUCKET=inventory-photos

# Shared access gate for the MVP.
# Store only a non-secret label publicly; keep the real code/password server-side.
NEXT_PUBLIC_SHARED_ACCESS_LABEL=Makerspace Staff Access
SHARED_ACCESS_CODE=

# Optional app/report metadata.
NEXT_PUBLIC_APP_NAME=Makerspace Facilities & Inventory Logbook
NEXT_PUBLIC_SCHOOL_NAME=

# Admin access code for the admin mode.
# Falls back to "admin" in development if not set.
ADMIN_ACCESS_CODE=

# Per-school access codes for observation feature API.
# In production, set to strong passwords in Vercel env vars.
SCHOOL_CODE_01=
SCHOOL_CODE_02=
SCHOOL_CODE_15=
SCHOOL_CODE_59=
SCHOOL_CODE_69=
